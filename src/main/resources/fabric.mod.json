{
	"schemaVersion": 1,
	"id": "fossilsarch2",
	"version": "${version}",
	"name": "Fossils & Archaeology 2",
	"description": "A faithful re-creation of the original prehistoric Minecraft experience. Discover fossils, extract DNA, cultivate eggs, and raise dinosaurs.",
	"authors": [
		"TotaraNZ"
	],
	"contact": {
		"sources": "https://github.com/TotaraNZ/fossils-and-archaeology-2"
	},
	"license": "MIT",
	"icon": "assets/fossilsarch2/icon.png",
	"accessWidener": "fossilsarch2.accesswidener",
	"mixins": [
		"fossilsarch2.mixins.json"
	],
	"environment": "*",
	"entrypoints": {
		"main": [
			"mod.fossilsarch2.FossilsArch2Mod"
		],
		"client": [
			"mod.fossilsarch2.FossilsArch2Client"
		],
		"fabric-datagen": [
			"mod.fossilsarch2.FossilsArch2DataGenerator"
		]
	},
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*",
		"geckolib": ">=5.5"
	}
}
